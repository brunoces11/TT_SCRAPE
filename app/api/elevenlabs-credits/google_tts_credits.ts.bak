// BACKUP — Google Cloud TTS Credits (original elevenlabs-credits/route.ts)
import { NextRequest, NextResponse } from "next/server";

export async function GET(request: NextRequest) {
  try {
    const characterCount = 0;
    const characterLimit = 1_000_000;
    const characterRemaining = characterLimit - characterCount;
    return NextResponse.json({ characterCount, characterLimit, characterRemaining });
  } catch (err) {
    const msg = err instanceof Error ? err.message : "Unknown error";
    return NextResponse.json({ error: msg }, { status: 500 });
  }
}
